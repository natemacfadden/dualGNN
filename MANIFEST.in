# Cython sources: the generated .c ships in the sdist too, but setup.py's
# cythonize() needs the .pyx present to build from an sdist at all
recursive-include src *.pyx
# The reference samplers are single-file (stb-style) C programs kept in .h;
# the .pyx compiles against them via `cdef extern`, so ship them in the sdist
recursive-include src *.h
